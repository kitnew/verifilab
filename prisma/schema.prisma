generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum VerifierType {
  EXACT_MATCH
  NUMERIC
  REGEX
  JSON_SCHEMA
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum TaskStatus {
  DRAFT
  IN_PROGRESS
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
}

enum ProjectRole {
  ADMIN
  AUTHOR
  REVIEWER
  CURATOR
  OPERATOR
}

enum AsyncJobType {
  BATCH_TASK_GENERATION
  BULK_IMPORT
  DATASET_RELEASE
  ROLLOUT_EVALUATION
  DATASET_QUALITY_SCAN
}

enum AsyncJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum GeneratorType {
  ARITHMETIC
  LINEAR_EQUATIONS
  STRING_TRANSFORMATIONS
  JSON_STRUCTURE
  REGEX_FORMAT
}

enum GenerationJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum EvaluationBatchStatus {
  DRAFT
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum EvaluationSourceType {
  MANUAL
  BULK_TEXT
  JSONL
  CSV
}

enum EvaluationResultStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  INVALID
  ERROR
}

enum TaskImportFormat {
  CSV
  JSON
  JSONL
}

enum TaskImportStatus {
  COMPLETED
  FAILED
  ROLLED_BACK
}

model Project {
  id               String              @id @default(cuid())
  name             String
  description      String              @default("")
  tasks            Task[]
  datasets         Dataset[]
  auditEvents      AuditEvent[]
  generationJobs   GenerationJob[]
  taskImports      TaskImport[]
  memberships      ProjectMembership[]
  asyncJobs        AsyncJob[]
  apiTokens        ApiToken[]
  guestWorkspaceId String?
  guestWorkspace   GuestWorkspace?     @relation(fields: [guestWorkspaceId], references: [id], onDelete: Cascade)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([guestWorkspaceId])
}

model User {
  id               String              @id @default(cuid())
  name             String
  email            String              @unique
  username         String?             @unique
  passwordHash     String?
  isActive         Boolean             @default(true)
  isAdmin          Boolean             @default(false)
  memberships      ProjectMembership[]
  authoredTasks    Task[]              @relation("TaskAuthor")
  reviewedTasks    Task[]              @relation("TaskReviewer")
  sessions         Session[]
  initiatedJobs    AsyncJob[]          @relation("AsyncJobInitiator")
  cancelledJobs    AsyncJob[]          @relation("AsyncJobCanceller")
  createdApiTokens ApiToken[]
  guestWorkspaceId String?
  guestWorkspace   GuestWorkspace?     @relation(fields: [guestWorkspaceId], references: [id], onDelete: Cascade)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([guestWorkspaceId])
}

model GuestWorkspace {
  id        String    @id @default(cuid())
  users     User[]
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model ProjectMembership {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ProjectRole
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([projectId, userId])
  @@index([userId, role])
}

model ApiToken {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  prefix      String
  tokenHash   String    @unique
  scopes      Json
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?

  @@index([projectId, createdAt])
  @@index([projectId, revokedAt])
  @@index([createdById])
}

model AsyncJob {
  id                      String         @id @default(cuid())
  projectId               String
  project                 Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  initiatorId             String?
  initiator               User?          @relation("AsyncJobInitiator", fields: [initiatorId], references: [id], onDelete: SetNull)
  type                    AsyncJobType
  status                  AsyncJobStatus @default(QUEUED)
  progress                Int            @default(0)
  input                   Json
  inputSummary            String
  resultReference         Json?
  safeErrorMessage        String?
  retrySourceId           String?
  retrySource             AsyncJob?      @relation("AsyncJobRetries", fields: [retrySourceId], references: [id], onDelete: SetNull)
  retries                 AsyncJob[]     @relation("AsyncJobRetries")
  idempotencyKey          String?        @unique
  cancellationRequestedAt DateTime?
  cancelledAt             DateTime?
  cancelledById           String?
  cancelledBy             User?          @relation("AsyncJobCanceller", fields: [cancelledById], references: [id], onDelete: SetNull)
  startedAt               DateTime?
  completedAt             DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  @@index([projectId, createdAt])
  @@index([projectId, status, type])
  @@index([initiatorId, createdAt])
  @@index([retrySourceId])
}

model TaskImport {
  id             String           @id @default(cuid())
  projectId      String
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filename       String
  format         TaskImportFormat
  status         TaskImportStatus
  strategy       String
  totalCount     Int
  importedCount  Int
  replacedCount  Int
  skippedCount   Int
  duplicateCount Int
  failedCount    Int
  rejectedRows   Json
  changes        Json
  createdAt      DateTime         @default(now())
  completedAt    DateTime?
  rolledBackAt   DateTime?

  @@index([projectId, createdAt])
}

model Task {
  id                    String            @id @default(cuid())
  projectId             String
  project               Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title                 String
  prompt                String
  verifierType          VerifierType
  verifierConfig        Json
  difficulty            Difficulty
  status                TaskStatus        @default(DRAFT)
  priority              TaskPriority      @default(MEDIUM)
  assignedAuthorId      String?
  assignedAuthor        User?             @relation("TaskAuthor", fields: [assignedAuthorId], references: [id], onDelete: SetNull)
  assignedReviewerId    String?
  assignedReviewer      User?             @relation("TaskReviewer", fields: [assignedReviewerId], references: [id], onDelete: SetNull)
  dueDate               DateTime?
  authorAssignedAt      DateTime?
  reviewerAssignedAt    DateTime?
  submittedAt           DateTime?
  completedAt           DateTime?
  tags                  Json
  expectedAnswer        String?
  generatorTemplate     GeneratorType?
  generatorVersion      Int?
  generationSeed        String?
  generationBatchId     String?
  generationJob         GenerationJob?    @relation(fields: [generationBatchId], references: [id], onDelete: SetNull)
  generationFingerprint String?
  evaluationBatches     EvaluationBatch[]
  verifierVersions      VerifierVersion[]
  verificationRuns      VerificationRun[]
  reviewComments        ReviewComment[]
  datasetItems          DatasetItem[]
  auditEvents           AuditEvent[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@unique([projectId, generationFingerprint])
  @@index([projectId])
  @@index([assignedAuthorId, status])
  @@index([assignedReviewerId, status])
  @@index([dueDate, status])
  @@index([generationBatchId])
}

model VerifierVersion {
  id               String            @id @default(cuid())
  taskId           String
  task             Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  version          Int
  verifierType     VerifierType
  verifierConfig   Json
  changeSummary    String?
  verificationRuns VerificationRun[]
  createdAt        DateTime          @default(now())

  @@unique([taskId, version])
  @@index([taskId, createdAt])
}

model EvaluationBatch {
  id                     String                @id @default(cuid())
  taskId                 String
  task                   Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  name                   String
  description            String                @default("")
  status                 EvaluationBatchStatus @default(DRAFT)
  sourceType             EvaluationSourceType
  modelName              String?
  modelVersion           String?
  temperature            Float?
  topP                   Float?
  seed                   Int?
  requestedCount         Int
  processedCount         Int                   @default(0)
  passedCount            Int                   @default(0)
  failedCount            Int                   @default(0)
  importInvalidCount     Int                   @default(0)
  invalidCount           Int                   @default(0)
  errorCount             Int                   @default(0)
  duplicateCount         Int                   @default(0)
  progress               Int                   @default(0)
  errorMessage           String?
  taskTitleSnapshot      String
  taskPromptSnapshot     String
  verifierTypeSnapshot   VerifierType
  verifierConfigSnapshot Json
  taskUpdatedAtSnapshot  DateTime
  importFingerprint      String?
  createdBy              String?
  results                EvaluationResult[]
  startedAt              DateTime?
  completedAt            DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@unique([taskId, importFingerprint])
  @@index([taskId, createdAt])
  @@index([status, createdAt])
  @@index([modelName])
}

model EvaluationResult {
  id                  String                 @id @default(cuid())
  evaluationBatchId   String
  evaluationBatch     EvaluationBatch        @relation(fields: [evaluationBatchId], references: [id], onDelete: Cascade)
  sequenceNumber      Int
  candidateResponse   String
  modelName           String?
  modelVersion        String?
  temperature         Float?
  seed                Int?
  externalId          String?
  metadata            Json?
  status              EvaluationResultStatus @default(PENDING)
  passed              Boolean?
  reward              Int?
  details             String?
  normalizedCandidate String?
  executionTimeMs     Float?
  errorMessage        String?
  evaluatedAt         DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@unique([evaluationBatchId, sequenceNumber])
  @@index([evaluationBatchId, status, sequenceNumber])
  @@index([evaluationBatchId, reward])
  @@index([externalId])
}

model GenerationJob {
  id               String              @id @default(cuid())
  projectId        String
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status           GenerationJobStatus @default(QUEUED)
  requestedCount   Int
  generatedCount   Int                 @default(0)
  seed             String
  generatorType    GeneratorType
  generatorVersion Int                 @default(1)
  difficulty       Difficulty
  progress         Int                 @default(0)
  errorMessage     String?
  tasks            Task[]
  createdAt        DateTime            @default(now())
  completedAt      DateTime?

  @@index([projectId])
  @@index([createdAt])
}

model VerificationRun {
  id                String          @id @default(cuid())
  taskId            String
  task              Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  verifierVersionId String
  verifierVersion   VerifierVersion @relation(fields: [verifierVersionId], references: [id], onDelete: Cascade)
  candidate         String
  passed            Boolean
  details           Json
  createdAt         DateTime        @default(now())

  @@index([taskId])
  @@index([verifierVersionId])
}

model ReviewComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    String
  body      String
  createdAt DateTime @default(now())

  @@index([taskId])
}

model Dataset {
  id            String                @id @default(cuid())
  projectId     String
  project       Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  description   String                @default("")
  items         DatasetItem[]
  versions      DatasetVersion[]
  releases      DatasetRelease[]
  qualityReport DatasetQualityReport?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([projectId])
}

model DatasetRelease {
  id                   String   @id @default(cuid())
  datasetId            String
  dataset              Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  version              String
  notes                String   @default("")
  seed                 String
  trainPercentage      Int
  validationPercentage Int
  testPercentage       Int
  totalCount           Int
  trainCount           Int
  validationCount      Int
  testCount            Int
  items                Json
  createdAt            DateTime @default(now())

  @@unique([datasetId, version])
  @@index([datasetId, createdAt])
}

model DatasetQualityReport {
  id                        String   @id @default(cuid())
  datasetId                 String   @unique
  dataset                   Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  taskCount                 Int
  overallScore              Int
  completenessScore         Int
  verifierValidityScore     Int
  duplicateSafetyScore      Int
  verificationEvidenceScore Int
  errorCount                Int
  warningCount              Int
  infoCount                 Int
  issues                    Json
  distributions             Json
  scannedAt                 DateTime @default(now())
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model DatasetVersion {
  id          String   @id @default(cuid())
  datasetId   String
  dataset     Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  version     Int
  name        String
  description String
  items       Json
  createdAt   DateTime @default(now())

  @@unique([datasetId, version])
  @@index([datasetId])
}

model DatasetItem {
  id        String  @id @default(cuid())
  datasetId String
  dataset   Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  taskId    String
  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  position  Int

  @@unique([datasetId, taskId])
  @@unique([datasetId, position])
  @@index([taskId])
}

model AuditEvent {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  action    String
  metadata  Json
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([taskId])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum VerifierType {
  EXACT_MATCH
  NUMERIC
  REGEX
  JSON_SCHEMA
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum TaskStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
}

enum GeneratorType {
  ARITHMETIC
  LINEAR_EQUATIONS
  STRING_TRANSFORMATIONS
  JSON_STRUCTURE
  REGEX_FORMAT
}

enum GenerationJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum EvaluationBatchStatus {
  DRAFT
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum EvaluationSourceType {
  MANUAL
  BULK_TEXT
  JSONL
  CSV
}

enum EvaluationResultStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  INVALID
  ERROR
}

model Project {
  id             String          @id @default(cuid())
  name           String
  description    String          @default("")
  tasks          Task[]
  datasets       Dataset[]
  auditEvents    AuditEvent[]
  generationJobs GenerationJob[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Task {
  id                    String            @id @default(cuid())
  projectId             String
  project               Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title                 String
  prompt                String
  verifierType          VerifierType
  verifierConfig        Json
  difficulty            Difficulty
  status                TaskStatus        @default(DRAFT)
  tags                  Json
  expectedAnswer        String?
  generatorTemplate     GeneratorType?
  generatorVersion      Int?
  generationSeed        String?
  generationBatchId     String?
  generationJob         GenerationJob?    @relation(fields: [generationBatchId], references: [id], onDelete: SetNull)
  generationFingerprint String?
  evaluationBatches     EvaluationBatch[]
  verificationRuns      VerificationRun[]
  reviewComments        ReviewComment[]
  datasetItems          DatasetItem[]
  auditEvents           AuditEvent[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@unique([projectId, generationFingerprint])
  @@index([projectId])
  @@index([generationBatchId])
}

model EvaluationBatch {
  id                     String                @id @default(cuid())
  taskId                 String
  task                   Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  name                   String
  description            String                @default("")
  status                 EvaluationBatchStatus @default(DRAFT)
  sourceType             EvaluationSourceType
  modelName              String?
  modelVersion           String?
  temperature            Float?
  topP                   Float?
  seed                   Int?
  requestedCount         Int
  processedCount         Int                   @default(0)
  passedCount            Int                   @default(0)
  failedCount            Int                   @default(0)
  importInvalidCount     Int                   @default(0)
  invalidCount           Int                   @default(0)
  errorCount             Int                   @default(0)
  duplicateCount         Int                   @default(0)
  progress               Int                   @default(0)
  errorMessage           String?
  taskTitleSnapshot      String
  taskPromptSnapshot     String
  verifierTypeSnapshot   VerifierType
  verifierConfigSnapshot Json
  taskUpdatedAtSnapshot  DateTime
  importFingerprint      String?
  createdBy              String?
  results                EvaluationResult[]
  startedAt              DateTime?
  completedAt            DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@unique([taskId, importFingerprint])
  @@index([taskId, createdAt])
  @@index([status, createdAt])
  @@index([modelName])
}

model EvaluationResult {
  id                  String                 @id @default(cuid())
  evaluationBatchId   String
  evaluationBatch     EvaluationBatch        @relation(fields: [evaluationBatchId], references: [id], onDelete: Cascade)
  sequenceNumber      Int
  candidateResponse   String
  modelName           String?
  modelVersion        String?
  temperature         Float?
  seed                Int?
  externalId          String?
  metadata            Json?
  status              EvaluationResultStatus @default(PENDING)
  passed              Boolean?
  reward              Int?
  details             String?
  normalizedCandidate String?
  executionTimeMs     Float?
  errorMessage        String?
  evaluatedAt         DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@unique([evaluationBatchId, sequenceNumber])
  @@index([evaluationBatchId, status, sequenceNumber])
  @@index([evaluationBatchId, reward])
  @@index([externalId])
}

model GenerationJob {
  id               String              @id @default(cuid())
  projectId        String
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status           GenerationJobStatus @default(QUEUED)
  requestedCount   Int
  generatedCount   Int                 @default(0)
  seed             String
  generatorType    GeneratorType
  generatorVersion Int                 @default(1)
  difficulty       Difficulty
  progress         Int                 @default(0)
  errorMessage     String?
  tasks            Task[]
  createdAt        DateTime            @default(now())
  completedAt      DateTime?

  @@index([projectId])
  @@index([createdAt])
}

model VerificationRun {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  candidate String
  passed    Boolean
  details   Json
  createdAt DateTime @default(now())

  @@index([taskId])
}

model ReviewComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    String
  body      String
  createdAt DateTime @default(now())

  @@index([taskId])
}

model Dataset {
  id            String                @id @default(cuid())
  projectId     String
  project       Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  description   String                @default("")
  items         DatasetItem[]
  versions      DatasetVersion[]
  releases      DatasetRelease[]
  qualityReport DatasetQualityReport?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([projectId])
}

model DatasetRelease {
  id                   String   @id @default(cuid())
  datasetId            String
  dataset              Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  version              String
  notes                String   @default("")
  seed                 String
  trainPercentage      Int
  validationPercentage Int
  testPercentage       Int
  totalCount           Int
  trainCount           Int
  validationCount      Int
  testCount            Int
  items                Json
  createdAt            DateTime @default(now())

  @@unique([datasetId, version])
  @@index([datasetId, createdAt])
}

model DatasetQualityReport {
  id                        String   @id @default(cuid())
  datasetId                 String   @unique
  dataset                   Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  taskCount                 Int
  overallScore              Int
  completenessScore         Int
  verifierValidityScore     Int
  duplicateSafetyScore      Int
  verificationEvidenceScore Int
  errorCount                Int
  warningCount              Int
  infoCount                 Int
  issues                    Json
  distributions             Json
  scannedAt                 DateTime @default(now())
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model DatasetVersion {
  id          String   @id @default(cuid())
  datasetId   String
  dataset     Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  version     Int
  name        String
  description String
  items       Json
  createdAt   DateTime @default(now())

  @@unique([datasetId, version])
  @@index([datasetId])
}

model DatasetItem {
  id        String  @id @default(cuid())
  datasetId String
  dataset   Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  taskId    String
  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  position  Int

  @@unique([datasetId, taskId])
  @@unique([datasetId, position])
  @@index([taskId])
}

model AuditEvent {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  action    String
  metadata  Json
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([taskId])
}
